# Copy this file to .env (gitignored, never commit real credentials) and
# fill in real values. docker-compose automatically loads .env from this
# same directory — no extra setup needed locally or when this gets synced
# to the NAS by scripts/deploy-docker.sh (which does not exclude .env from
# the transfer, matching how appsettings.json is already handled).

# PIA account credentials — NOT your PIA "site" login, use the actual VPN
# username (looks like pXXXXXXX) and password from your PIA account page.
PIA_USER=
PIA_PASSWORD=

# Optional. Comma-separated PIA region name(s), e.g. "US East". Leave blank
# to let Gluetun pick automatically. See:
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/servers.md
PIA_SERVER_REGIONS=

# Optional. Same PIA account, independent region choice for the torrent VPN
# gateway (gluetun-torrent) used by qBittorrent/Sonarr/Radarr. Leave blank
# to let Gluetun pick automatically.
PIA_TORRENT_SERVER_REGIONS=

# Sonarr/Radarr API keys — these are NOT chosen up front. Each app generates
# its own key on first boot (visible in its web UI under Settings General);
# deploy once, grab both keys from there, then fill these in and redeploy.
SONARR_API_KEY=
RADARR_API_KEY=

# Jellyfin API key — Dashboard -> Advanced -> API Keys -> create one. Used
# server-to-server to match Sonarr/Radarr's downloaded content to Jellyfin's
# own library items, for the embedded "Watch Now" player.
JELLYFIN_API_KEY=

# Your Tailscale MagicDNS hostname for this NAS (e.g.
# ugreen-nas.tailXXXXX.ts.net — find it via `tailscale status` or the
# Tailscale admin console). Used to build the Jellyfin embed URL and to
# scope the CSP header that allows the embedded player's iframe — kept out
# of committed files since it's specific to your own private tailnet.
TAILSCALE_HOSTNAME=
